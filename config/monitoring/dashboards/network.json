{
  "title": "Brain — Network",
  "uid": "brain-network",
  "schemaVersion": 39,
  "tags": ["brain"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(brain_connections_active)", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 2,
      "title": "Connection Accept Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(brain_connections_total[5m]))", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 3,
      "title": "Connection Close Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(brain_connections_closed_total[5m]))", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 4,
      "title": "Rejected Connections Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(brain_connections_rejected_total[5m]))", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 5,
      "title": "Frame Throughput (recv / send)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(brain_frame_recv_total[5m]))", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "sum(rate(brain_frame_send_total[5m]))", "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 6,
      "title": "Frame Size p99 (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(brain_frame_size_bytes_bucket[5m])))", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 7,
      "title": "Active Connections by Shard",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (shard) (brain_connections_active)", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
