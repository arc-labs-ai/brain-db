# Brain system schema. Loaded at MetadataDb::open via include_str!.
#
# Defines the built-in entity types, predicates, relation types, and
# extractors the substrate uses for bootstrapping. Users CANNOT
# redefine anything under the `brain:` namespace — the user-facing
# `validate()` rejects it; this seed path uses
# `validate_system_schema()` instead.
#
# Order matters: each intern path allocates ids monotonically, so
# source order in this file pins the seed ids. On a fresh DB:
#   EntityTypeId(1)  = Person
#   EntityTypeId(2)  = Organization
#   EntityTypeId(3)  = Project
#   EntityTypeId(4)  = Event
#   EntityTypeId(5)  = Place
#   EntityTypeId(6)  = Concept
#   PredicateId(1)   = brain:behavior_tone
#   PredicateId(2)   = brain:behavior_style
#   PredicateId(3)   = brain:behavior_avoids
#   PredicateId(4)   = brain:behavior_prefers
#   PredicateId(5)   = brain:behavior_constraint
#   RelationTypeId(1) = brain:related_to
#   RelationTypeId(2) = brain:reports_to
#   RelationTypeId(3) = brain:co_authored
#   RelationTypeId(4) = brain:family_of
#   ExtractorId(1) = brain:entity_mentions
#   ExtractorId(2) = brain:gliner
#   ExtractorId(3) = brain:llm_predicate
#
# NOTE — predicates are an OPEN vocabulary. The seed declares ONLY the five
# `behavior_*` predicates, because `MATERIALIZE_PROCEDURAL` resolves those by
# qname. Every other predicate (works_at, lives_in, knows, donated, …) is
# coined on the fly by `predicate_intern_or_get` at write time; semantics and
# supersession come from the statement's KIND, not from a pre-seeded predicate
# list. Seeding a fixed domain vocabulary would be unbounded and is exactly
# what the kinds model replaced — so domain predicates are deliberately NOT
# seeded here.

namespace brain

# --- Entity types -------------------------------------------------
#
# The six built-in nouns are passed verbatim (as `brain:<Name>`) to
# the zero-shot GLiNER classifier as its label set, so the classifier
# tracks the active schema's vocabulary without any per-schema
# retraining. Optional attributes are advisory hints the extractors /
# user code can populate but never required by the substrate.

define entity_type Person {
    attributes {
        email:    text optional unique
        role:     text optional
        team:     text optional
        timezone: text optional
    }
}

define entity_type Organization {
    attributes {
        domain:   text optional
        industry: text optional
    }
}

define entity_type Project {
    attributes {
        status:      text optional
        owner_qname: text optional
    }
}

define entity_type Event {
    attributes {
        occurred_at_unix_nanos: number optional
        location_qname:         text optional
    }
}

define entity_type Place {
    attributes {
        country: text optional
        kind:    text optional
    }
}

define entity_type Concept {
    attributes {
        description: text optional
    }
}

# --- Predicates (procedural memory only) --------------------------
#
# Behaviors an agent learns about itself over prior sessions. All five
# are Preference (stateful) — a fresh observation supersedes the prior
# one for the same `(subject, predicate)` pair. The object is always a
# free-text prompt fragment because procedural memory is consumed by
# an LLM, not the typed-graph retriever. `MATERIALIZE_PROCEDURAL` walks
# these predicates and renders them as a system block.

define predicate behavior_tone {
    kind: Preference
    object: Value<text>
    stateful: true
    description: "How the agent should phrase responses (e.g. 'concise', 'verbose', 'formal'). Single value at a time."
}

define predicate behavior_style {
    kind: Preference
    object: Value<text>
    stateful: true
    description: "Stylistic conventions the agent has learned to follow."
}

define predicate behavior_avoids {
    kind: Preference
    object: Value<text>
    stateful: true
    description: "Actions or topics the agent has learned to avoid."
}

define predicate behavior_prefers {
    kind: Preference
    object: Value<text>
    stateful: true
    description: "Approaches the agent has learned to favor."
}

define predicate behavior_constraint {
    kind: Preference
    object: Value<text>
    stateful: true
    description: "Hard rules the agent must follow across all sessions."
}

# --- Relation types -----------------------------------------------
#
# Typed edges between entities. Distinct from predicates — relations
# carry no object value, only a from / to entity pair.

define relation_type related_to {
    from: Any
    to: Any
    cardinality: many-to-many
    symmetric: true
    description: "Generic relation between entities when no more specific type fits."
}

define relation_type reports_to {
    from: Any
    to: Any
    cardinality: many-to-one
    description: "Organizational reporting line. Second create on same `from` auto-supersedes."
}

define relation_type co_authored {
    from: Any
    to: Any
    cardinality: many-to-many
    symmetric: true
    description: "Symmetric co-authorship of a memory or artifact; canonicalises from / to byte-wise."
}

define relation_type family_of {
    from: Person
    to: Person
    cardinality: many-to-many
    symmetric: true
    description: "Kinship between two people (schema parent/child/sibling/spouse); the specific role is carried in the statement detail, not the relation type."
}

# --- Built-in extractors -----------------------------------------
#
# Three tiers register at MetadataDb::open via the system-schema
# bootstrap → schema_apply → extractor_intern path. brain-server's
# shard spawn materialises them into the runtime `ExtractorRegistry`
# so they fire on every ENCODE.
#
# Extractor IDs are stable across reopens because intern allocates
# `max(existing) + 1`; on a fresh DB:
#   entity_mentions → ExtractorId(1)
#   gliner          → ExtractorId(2)
#   llm_predicate   → ExtractorId(3)
#
# Targets use `entity_or_statement` because each tier emits across
# the full six-entity-type label space (Person / Organization /
# Project / Event / Place / Concept) plus statements; the runtime
# kind-routing in brain-extractors fans out per emitted item.

define extractor entity_mentions {
    kind: pattern
    target: entity_or_statement
    patterns [
        /\b([A-Z][a-z]+(?:\s+[A-Z][a-z]+)+)\b/,
        /\b([A-Z]\.\s*[A-Z][a-z]+)\b/
    ]
    confidence: 0.7
}

define extractor gliner {
    kind: classifier
    target: entity_or_statement
    model: "gliner-small-v2.1"
    feature_extraction: builtin
    confidence_threshold: 0.5
    trigger: on encode
}

define extractor llm_predicate {
    kind: llm
    target: entity_or_statement
    model: "gpt-4o-mini"
    prompt: """You extract durable, factual knowledge from one memory at a time as clean subject–predicate–object triples for a memory database. Extract only genuine, lasting facts, preferences, and relationships about the entities — NOT conversational filler, greetings, reactions, or in-the-moment feelings.

The active schema declares these entity types:
- brain:Person
- brain:Organization
- brain:Project
- brain:Event
- brain:Place
- brain:Concept

PREDICATES ARE OPEN. Capture the real relation as a short snake_case predicate taken from the text — do NOT restrict yourself to a fixed list, and NEVER omit a genuine fact just because no predefined predicate fits. Examples: "works at" -> works_at; "lives in" -> lives_in; "donated bone marrow to" -> donated; "is allergic to" -> allergic_to; "favorite color is" -> favorite_color. Reuse a common name when natural so the same relation isn't spelled two different ways. Emit each predicate as `brain:<snake_case>`.

Classify each statement into exactly ONE kind from the list below. The kind is the *shape* of the fact, not its topic. If none truly fits, use Fact.

Kinds — `Name (cardinality, temporal): what belongs here`:
{DECLARED_KINDS}

Output STRICT JSON matching this shape, and nothing else:
{
  "statements": [
    { "subject": "Alice Wong", "predicate": "brain:works_at", "object": "Acme Corp", "object_is_entity": true, "kind": "Relation", "confidence": 0.92 },
    { "subject": "Bob Smith", "predicate": "brain:lives_in", "object": "Berlin", "object_is_entity": true, "kind": "Attribute", "confidence": 0.9 },
    { "subject": "Eve Adams", "predicate": "brain:favorite_color", "object": "blue", "object_is_entity": false, "kind": "Attribute", "confidence": 0.88 },
    { "subject": "Frank Brown", "predicate": "brain:traveled_to", "object": "Paris", "object_is_entity": true, "kind": "Event", "event_at": "2020-01-15", "confidence": 0.9 },
    { "subject": "I", "predicate": "brain:prefers", "object": "dark roast coffee", "object_is_entity": false, "subject_is_self": true, "kind": "Preference", "confidence": 0.95 },
    { "subject": "Priya", "predicate": "brain:works_at", "object": "Google", "object_is_entity": true, "kind": "Relation", "retract": true, "confidence": 0.9 }
  ]
}

Rules:
- Decompose each assertion into a clean (subject, predicate, object). The predicate is the relation; the object is the entity or a short clean value it acts on — NEVER a verb phrase or sentence fragment. "Alice works at Acme" -> predicate "brain:works_at", object "Acme Corp" (NOT "works at Acme").
- `object_is_entity`: set true when the object names a thing (a person, organization, place, product, concept — something that could have its own facts), e.g. "Acme Corp", "Paris", "aspirin"; set false when the object is a literal value, e.g. "blue", "42", "Senior Engineer". When unsure, prefer false.
- `event_at`: for Event-kind statements ONLY, the date it happened as an ISO date string ("YYYY-MM-DD", or just "YYYY" if only the year is known). Omit it for non-Events and when no date is stated — do NOT invent one.
- `subject_is_self`: set true when the subject is the speaker / author of this memory referring to THEMSELVES — first person in ANY language ("I", "me", "my", "yo", "私", "ich", "moi", …). Keep the original surface in `subject`; the system attributes the fact to the writing agent. Set false (or omit) for everyone else, including the person the author is addressing ("you").
- Predicates are open: capture the real relation verbatim in snake_case. Do NOT omit a genuine, durable fact just because its relation is unusual — that is exactly what open predicates are for ("donated", "allergic_to", "favorite_color").
- Choosing the kind: Attribute = a single-valued property of the entity (current city, role, age, favorite color); Relation = a link to another entity (works_at, knows, manages, married_to); Preference = likes / wants / avoids something; Event = something that happened at a point in time (donated, traveled, met, shipped); Directive = how the agent should behave; Fact = anything that fits none of the above (the catch-all).
- Negation & change: when the text says a fact NO LONGER holds ("not at Google anymore", "no longer drinks coffee", "used to live in Paris but moved"), emit that former fact as a triple marked `"retract": true` (subject, predicate, and the OLD object — e.g. works_at Google with retract:true) so the database retires the prior record. If a NEW current value is also stated ("now works at OpenAI"), emit it too as a normal triple (no retract). A plain statement with no `retract` key is a normal current assertion; only set `retract` when the text explicitly denies/ends a fact.
- Resolve pronouns before emitting. Replace "it / he / she / they / this / that" with the actual entity they refer to within this text; never output a bare pronoun, and never leave a pronoun stuck to a value ("usually drinks it black" -> predicate "brain:usually_drinks", object "black" — the manner — NOT "it black"). If a pronoun's referent is genuinely unclear, drop that triple rather than emit the pronoun.
- Quality over coverage. Extract durable facts / preferences / relationships / events, not conversational noise: skip greetings, reactions ("that's awesome"), momentary feelings, and vague statements. Emitting nothing is better than a wrong or vague triple.
- Extract assertions about possessive or implied subjects too ("Melanie's kids love dinosaurs" -> subject "Melanie's kids").
- Every entity gets its OWN attributes. When a sentence states a fact about an entity that appears as the object, in an apposition, or in a subordinate clause — not just the grammatical subject — emit a separate triple with THAT entity as the subject. An apposition ("Rohan, a lawyer", "Meera's husband Rohan, who studied at NLSIU") describes the named entity: emit "Rohan -> brain:occupation -> lawyer" and "Rohan -> brain:studied_at -> NLSIU", in addition to any relation tying it to the main subject ("Meera -> brain:spouse -> Rohan"). A role-at-org clause ("Niraj is a senior engineer at NeuraCorp") yields BOTH the role as an attribute ("Niraj -> brain:role -> senior engineer") AND the affiliation as a relation ("Niraj -> brain:works_at -> NeuraCorp"). Decompose so each entity becomes a complete, independently-queryable subject — never leave an entity's stated attribute attached only to the sentence that introduced it.
- Use the entity surface forms verbatim from the "Previously extracted entities" section below as `subject` / `object` whenever the assertion involves one of them. Do not invent new surface forms for those concepts.
- If the text contains no durable assertion, return `{ "statements": [] }`.
{PRIOR_ENTITIES}
Input text:
```
{TEXT}
```"""
    confidence_threshold: 0.7
}
